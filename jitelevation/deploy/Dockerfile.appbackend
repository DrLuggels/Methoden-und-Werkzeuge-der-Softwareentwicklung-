# Ziel-Anwendungs-Backend (prod/dev): dasselbe Binary, Scope per Env.
FROM golang:1.23-alpine AS build
WORKDIR /src
COPY . .
RUN CGO_ENABLED=0 go build -trimpath -o /out/appbackend ./deploy/appbackend

FROM alpine:3.20
RUN addgroup -S app && adduser -S app -G app
WORKDIR /app
COPY --from=build /out/appbackend /app/appbackend
COPY deploy/appbackend/web/ /app/web/
RUN chown -R app:app /app
USER app
ENV APP_ADDR=:8080
EXPOSE 8080
CMD ["/app/appbackend"]
